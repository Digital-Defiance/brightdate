{
  "name": "@brightchain/brightdate",
  "version": "0.32.6",
  "description": "BrightDate - A scientifically grounded universal decimal time system based on J2000.0 epoch and TAI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Digital-Defiance/BrightDate.git"
  },
  "homepage": "https://github.com/Digital-Defiance/BrightDate#readme",
  "bugs": {
    "url": "https://github.com/Digital-Defiance/BrightDate/issues"
  },
  "keywords": [
    "time",
    "timestamp",
    "stardate",
    "julian-date",
    "tai",
    "j2000",
    "decimal-time",
    "universal-time",
    "brightdate"
  ],
  "author": "Digital Defiance",
  "license": "MIT",
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "fast-check": "^4.7.0",
    "jest": "^30.0.5",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "build:prod": "tsc -b tsconfig.lib.json --force",
    "test": "jest --config jest.config.cts",
    "lint": "eslint 'src/**/*.ts'",
    "prepublishOnly": "npm run build:prod",
    "publish:npm": "npm run build:prod && npm publish"
  },
  "publishConfig": {
    "access": "public"
  }
}
