{
  "name": "brightdate",
  "sourceRoot": "brightdate/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:standalone"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/brightdate",
        "main": "brightdate/src/index.ts",
        "tsConfig": "brightdate/tsconfig.lib.json",
        "assets": [
          {
            "input": "brightdate",
            "glob": "*.md",
            "output": "."
          },
          {
            "input": "brightdate",
            "glob": "package.json",
            "output": "."
          }
        ]
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public",
        "cwd": "dist/brightdate"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "brightdate/**/*.ts"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "brightdate/jest.config.ts",
        "codeCoverage": false
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true,
          "coverageReporters": [
            "text",
            "lcov"
          ],
          "collectCoverageFrom": [
            "src/**/*.ts"
          ]
        }
      }
    }
  }
}
